<% layout('layouts/boilerplate') %>
<div class="row mt-3">
    <div class="alert alert-danger col-6 offset-3" role="alert">
        <h4 class="alert-heading">Something went wrong!</h4>
        <p><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
        <hr>
        <p class="mb-0">
            Please try again later or go back to the <a href="/listings" class="alert-link">Listings Section</a>.
        </p>
    </div>
</div>