<% layout('layouts/boilerplate') %>
<%
  const totalListings = allListings ? allListings.length : 0;
  const categoryItems = [
    { label: "Homes", value: "Homes", icon: "fa-house" },
    { label: "Experiences", value: "Experiences", icon: "fa-map-location-dot" },
    { label: "Services", value: "Services", icon: "fa-suitcase-rolling" }
  ];
  const filtersActive = Boolean(searchTerm || activeCategory);
  const toCardImage = (listing) => listing.image && listing.image.url
    ? listing.image.url
    : "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80";
  const buildCategoryUrl = (value) => {
    const params = new URLSearchParams();
    if (value) params.set("category", value);
    if (searchTerm) params.set("search", searchTerm);
    const qs = params.toString();
    return qs ? `/listings?${qs}` : "/listings";
  };
%>

<main class="listing-page">
    <section class="listing-hero">
        <div class="listing-hero__copy">
            <span class="listing-kicker">
                <i class="fa-solid fa-sparkles"></i>
                Travel made simple
            </span>
            <h1>Book beautiful stays with an Airbnb-inspired mobile experience.</h1>
            <p>
                Browse curated destinations, switch categories in one tap, and keep the whole booking flow compact on any screen.
            </p>
        </div>
        <div class="listing-hero__stats">
            <article>
                <strong><%= totalListings %></strong>
                <span>Available tours</span>
            </article>
            <article>
                <strong><%= [...new Set((allListings || []).map(item => item.country).filter(Boolean))].length %></strong>
                <span>Countries</span>
            </article>
        </div>
    </section>

    <section class="listing-toolbar">
        <div>
            <span class="section-kicker">Popular destinations</span>
            <h2>Explore destinations</h2>
        </div>
        <% if(currUser) { %>
            <a href="/listings/new" class="listing-toolbar__cta">
                <i class="fa-solid fa-plus"></i>
                Add Tour
            </a>
        <% } %>
    </section>

    <nav class="listing-categories" aria-label="Listing categories">
        <button class="listing-chip <%= !activeCategory ? 'is-active' : '' %>" type="button" data-category-url="<%= buildCategoryUrl('') %>">
            <i class="fa-solid fa-border-all"></i>
            <span>All</span>
        </button>
        <% categoryItems.forEach((category) => { %>
            <button
                class="listing-chip <%= activeCategory && activeCategory.toLowerCase() === category.value.toLowerCase() ? 'is-active' : '' %>"
                type="button"
                data-category-url="<%= buildCategoryUrl(category.value) %>"
            >
                <i class="fa-solid <%= category.icon %>"></i>
                <span><%= category.label %></span>
            </button>
        <% }) %>
    </nav>

    <% if(filtersActive) { %>
        <div class="listing-filter">
            <div>
                Showing <strong><%= totalListings %></strong> result<%= totalListings === 1 ? "" : "s" %>
                <% if(searchTerm) { %> for <strong>"<%= searchTerm %>"</strong><% } %>
                <% if(activeCategory) { %> in <strong><%= activeCategory %></strong><% } %>
            </div>
            <a href="/listings" class="listing-filter__clear">Clear filters</a>
        </div>
    <% } %>

    <section class="listing-section">
        <div class="listing-section__head">
            <div>
                <span class="section-kicker">Featured stays</span>
                <h2>Popular destinations</h2>
            </div>
            <p>Designed for touch-first browsing with smooth horizontal scrolling on mobile and a clean grid on larger screens.</p>
        </div>

        <% if(totalListings > 0) { %>
            <div class="listing-carousel">
                <% allListings.forEach((listing) => { %>
                    <a class="listing-card" href="/listings/<%= listing._id %>">
                        <div class="listing-card__media">
                            <img src="<%= toCardImage(listing) %>" alt="<%= listing.title %>">
                            <span class="listing-card__badge">Guest favourite</span>
                            <span class="listing-card__wish" aria-hidden="true">
                                <i class="fa-regular fa-heart"></i>
                            </span>
                        </div>
                        <div class="listing-card__body">
                            <div class="listing-card__meta">
                                <span><%= [listing.location, listing.country].filter(Boolean).join(", ") || "Destination" %></span>
                                <span class="listing-card__rating"><i class="fa-solid fa-star"></i> 4.8</span>
                            </div>
                            <h3><%= listing.title %></h3>
                            <p><%= listing.description || "A thoughtfully selected stay with modern comfort and great location." %></p>
                            <div class="listing-card__footer">
                                <div class="listing-card__price">
                                    <strong>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></strong>
                                    <span>/ night</span>
                                </div>
                                <span class="listing-card__arrow"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } else { %>
            <div class="listing-empty">
                <i class="fa-regular fa-map"></i>
                <h3>No listings found</h3>
                <p>Try a different search or category to explore more destinations.</p>
            </div>
        <% } %>
    </section>
</main>
