<% layout('layouts/boilerplate') %>
<%
  const totalListings = allListings ? allListings.length : 0;
  const countries = [...new Set((allListings || []).map(item => item.country).filter(Boolean))];
  const categoryOptions = [
    { label: "Beach", value: "Beach", icon: "fa-umbrella-beach" },
    { label: "Mountain", value: "Mountain", icon: "fa-mountain-sun" },
    { label: "City", value: "City", icon: "fa-city" },
    { label: "Camping", value: "Camping", icon: "fa-campground" },
    { label: "Lake", value: "Lake", icon: "fa-water" },
    { label: "Arctic", value: "Arctic", icon: "fa-snowflake" },
    { label: "Desert", value: "Desert", icon: "fa-sun" },
    { label: "Trending", value: "Trending", icon: "fa-fire" }
  ];
  const hasFilters = Boolean(searchTerm || activeCategory);
%>

<style>
  .tours-page {
    --tour-ink: var(--app-ink);
    --tour-muted: var(--app-muted);
    --tour-line: var(--app-line);
    --tour-accent: var(--app-accent);
    --tour-surface: var(--app-surface);
    --tour-soft: var(--app-surface-soft);
    color: var(--tour-ink);
    padding: 1.35rem 0 4rem;
  }

  .tours-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .tours-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: end;
    margin-bottom: 1.75rem;
    padding: clamp(1.35rem, 4vw, 2.1rem);
    border: 1px solid var(--tour-line);
    border-radius: 1.5rem;
    background: linear-gradient(135deg, var(--tour-surface) 0%, var(--tour-soft) 52%, rgba(254, 66, 77, 0.1) 100%);
    box-shadow: 0 22px 60px var(--app-shadow);
  }

  .tours-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--tour-accent);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  .tours-title {
    margin: 0.45rem 0 0.6rem;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.02;
  }

  .tours-subtitle {
    color: var(--tour-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    margin: 0;
    max-width: 42rem;
  }

  .tours-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(7.5rem, 1fr));
    gap: 0.8rem;
    min-width: 17rem;
  }

  .tour-stat {
    padding: 1rem;
    border: 1px solid var(--tour-line);
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--tour-surface) 84%, transparent);
  }

  .tour-stat strong {
    display: block;
    font-size: 1.7rem;
    font-weight: 850;
    line-height: 1;
  }

  .tour-stat span {
    color: var(--tour-muted);
    display: block;
    font-size: 0.78rem;
    font-weight: 750;
    margin-top: 0.35rem;
  }

  .tours-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .category-strip {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 1.35rem;
    overflow-x: auto;
    padding: 0.15rem 0 0.55rem;
    scrollbar-width: thin;
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex: 0 0 auto;
    min-height: 3rem;
    padding: 0.62rem 0.92rem;
    border: 1px solid var(--tour-line);
    border-radius: 999px;
    background: var(--tour-surface);
    color: var(--tour-muted);
    font-size: 0.86rem;
    font-weight: 850;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(23, 32, 51, 0.05);
    transition: background-color 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .category-pill i {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    color: var(--tour-accent);
    background: rgba(254, 66, 77, 0.1);
  }

  .category-pill:hover,
  .category-pill.is-active {
    color: var(--app-action-text);
    background: var(--app-action-bg);
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(23, 32, 51, 0.14);
  }

  .category-pill:hover i,
  .category-pill.is-active i {
    color: var(--app-action-text);
    background: rgba(255, 255, 255, 0.16);
  }

  .filter-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.1rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--tour-line);
    border-radius: 1rem;
    background: var(--tour-surface);
    color: var(--tour-muted);
  }

  .filter-summary strong {
    color: var(--tour-ink);
  }

  .clear-filter {
    color: var(--tour-accent);
    font-size: 0.86rem;
    font-weight: 850;
    text-decoration: none;
    white-space: nowrap;
  }

  .tours-toolbar h3 {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 850;
  }

  .tours-toolbar p {
    color: var(--tour-muted);
    margin: 0.25rem 0 0;
  }

  .add-tour-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    padding: 0.72rem 1.05rem;
    border-radius: 999px;
    color: var(--app-action-text);
    background: var(--app-action-bg);
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 12px 26px var(--app-shadow);
    transition: transform 160ms ease, background-color 160ms ease, box-shadow 160ms ease;
  }

  .add-tour-btn:hover {
    color: #fff;
    background: var(--tour-accent);
    transform: translateY(-1px);
    box-shadow: 0 16px 30px rgba(254, 66, 77, 0.24);
  }

  .tours-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .tour-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    border: 1px solid var(--tour-line);
    border-radius: 1.35rem;
    background: var(--tour-surface);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 16px 42px var(--app-shadow);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .tour-card:hover {
    color: inherit;
    border-color: rgba(254, 66, 77, 0.28);
    transform: translateY(-5px);
    box-shadow: 0 24px 58px var(--app-shadow);
  }

  .tour-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--tour-soft);
  }

  .tour-card__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: scale(1.01);
    transition: transform 260ms ease;
  }

  .tour-card:hover .tour-card__media img {
    transform: scale(1.06);
  }

  .tour-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 42%, rgba(0, 0, 0, 0.5) 100%);
    pointer-events: none;
  }

  .tour-card__save,
  .tour-card__location {
    position: absolute;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    color: #fff;
    background: rgba(12, 18, 28, 0.68);
    backdrop-filter: blur(12px);
  }

  .tour-card__save {
    top: 0.9rem;
    right: 0.9rem;
    justify-content: center;
    width: 2.55rem;
    height: 2.55rem;
    border-radius: 50%;
  }

  .tour-card__location {
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.9rem;
    gap: 0.45rem;
    width: fit-content;
    max-width: calc(100% - 1.8rem);
    padding: 0.58rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .tour-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
  }

  .tour-card__title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 850;
    line-height: 1.35;
  }

  .tour-card__description {
    color: var(--tour-muted);
    display: -webkit-box;
    font-size: 0.88rem;
    line-height: 1.55;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .tour-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    margin-top: auto;
    padding-top: 0.9rem;
    border-top: 1px solid var(--tour-line);
  }

  .tour-price {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 850;
  }

  .tour-price span {
    color: var(--tour-muted);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .tour-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: var(--tour-accent);
    font-size: 0.82rem;
    font-weight: 850;
    white-space: nowrap;
  }

  .tours-empty {
    padding: 3rem 1.5rem;
    border: 1px dashed var(--tour-line);
    border-radius: 1.35rem;
    background: var(--tour-surface);
    color: var(--tour-muted);
    text-align: center;
  }

  .tours-empty i {
    color: var(--tour-accent);
    font-size: 2rem;
    margin-bottom: 0.8rem;
  }

  .tours-empty h3 {
    color: var(--tour-ink);
    font-weight: 850;
    margin: 0;
  }

  @media (max-width: 991px) {
    .tours-hero {
      grid-template-columns: 1fr;
    }

    .tours-stats {
      min-width: 0;
    }

    .tours-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .tours-page {
      padding-top: 0.75rem;
    }

    .tours-hero {
      border-radius: 1.1rem;
    }

    .tours-toolbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .filter-summary {
      align-items: flex-start;
      flex-direction: column;
    }

    .add-tour-btn {
      width: 100%;
      justify-content: center;
    }

    .tours-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="tours-page">
  <div class="tours-shell">
    <section class="tours-hero">
      <div>
        <span class="tours-kicker"><i class="fa-solid fa-compass"></i> All tours</span>
        <h1 class="tours-title">Find your next stay-worthy escape</h1>
        <p class="tours-subtitle">
          Search by destination, switch categories with one tap, and browse tour previews with clear pricing and location details.
        </p>
      </div>
      <div class="tours-stats">
        <div class="tour-stat">
          <strong><%= totalListings %></strong>
          <span>available tours</span>
        </div>
        <div class="tour-stat">
          <strong><%= countries.length %></strong>
          <span>countries</span>
        </div>
      </div>
    </section>

    <nav class="category-strip" aria-label="Tour categories">
      <a
        class="category-pill <%= !activeCategory ? 'is-active' : '' %>"
        href="/listings<%= searchTerm ? `?search=${encodeURIComponent(searchTerm)}` : '' %>"
      >
        <i class="fa-solid fa-layer-group"></i>
        All
      </a>
      <% for(const category of categoryOptions) { %>
        <a
          class="category-pill <%= activeCategory.toLowerCase() === category.value.toLowerCase() ? 'is-active' : '' %>"
          href="/listings?category=<%= encodeURIComponent(category.value) %><%= searchTerm ? `&search=${encodeURIComponent(searchTerm)}` : '' %>"
        >
          <i class="fa-solid <%= category.icon %>"></i>
          <%= category.label %>
        </a>
      <% } %>
    </nav>

    <% if(hasFilters) { %>
      <div class="filter-summary">
        <span>
          Showing <strong><%= totalListings %></strong> result<%= totalListings === 1 ? "" : "s" %>
          <% if(searchTerm) { %> for <strong>"<%= searchTerm %>"</strong><% } %>
          <% if(activeCategory) { %> in <strong><%= activeCategory %></strong><% } %>
        </span>
        <a class="clear-filter" href="/listings">Clear filters</a>
      </div>
    <% } %>

    <div class="tours-toolbar">
      <div>
        <h3>Explore destinations</h3>
        <p><%= totalListings %> tour<%= totalListings === 1 ? "" : "s" %> ready to browse</p>
      </div>
      <% if(currUser) { %>
        <a href="/listings/new" class="add-tour-btn">
          <i class="fa-solid fa-plus"></i> Add tour
        </a>
      <% } %>
    </div>

    <% if(totalListings > 0) { %>
      <div class="tours-grid">
        <% for(let listing of allListings) { %>
          <a href="/listings/<%= listing._id %>" class="tour-card">
            <div class="tour-card__media">
              <img
                src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=900&q=80' %>"
                alt="<%= listing.title %>"
              />
              <span class="tour-card__save" aria-hidden="true">
                <i class="fa-regular fa-heart"></i>
              </span>
              <span class="tour-card__location">
                <i class="fa-solid fa-location-dot"></i>
                <%= [listing.location, listing.country].filter(Boolean).join(", ") || "Destination" %>
              </span>
            </div>
            <div class="tour-card__body">
              <div>
                <h2 class="tour-card__title"><%= listing.title %></h2>
                <p class="tour-card__description">
                  <%= listing.description || "A thoughtfully listed tour with destination details and daily pricing." %>
                </p>
              </div>
              <div class="tour-card__footer">
                <p class="tour-price">
                  &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                  <span>/ day</span>
                </p>
                <span class="tour-card__cta">
                  View <i class="fa-solid fa-arrow-right"></i>
                </span>
              </div>
            </div>
          </a>
        <% } %>
      </div>
    <% } else { %>
      <div class="tours-empty">
        <i class="fa-regular fa-map"></i>
        <h3>No tours yet</h3>
        <p>Add your first destination to start building the collection.</p>
      </div>
    <% } %>
  </div>
</main>
