<% layout('layouts/boilerplate') %>
<%
  const destination = [listing.location, listing.country].filter(Boolean).join(", ");
  const mapQuery = encodeURIComponent(destination);
  const reviewCount = listing.reviews ? listing.reviews.length : 0;
  const averageRating = reviewCount
    ? listing.reviews.reduce((total, item) => total + item.rating, 0) / reviewCount
    : null;
  const canManageListing = currUser && (isAdmin || (listing.owner && currUser._id.equals(listing.owner._id)));
%>

<style>
  .listing-show {
    --show-ink: #172033;
    --show-muted: #667085;
    --show-line: #e7ebf0;
    --show-accent: #fe424d;
    --show-soft: #f7f9fb;
    color: var(--show-ink);
    padding: 1.25rem 0 4rem;
  }

  .show-shell {
    max-width: 1120px;
    margin: 0 auto;
  }

  .show-hero {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.55fr);
    align-items: stretch;
  }

  .show-media {
    min-height: 520px;
    overflow: hidden;
    position: relative;
    border-radius: 1.5rem;
    background: #eef2f6;
    box-shadow: 0 24px 70px rgba(23, 32, 51, 0.12);
  }

  .show-media img {
    width: 100%;
    height: 100%;
    min-height: 520px;
    display: block;
    object-fit: cover;
  }

  .show-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.42) 100%);
    pointer-events: none;
  }

  .show-media-badge {
    position: absolute;
    left: 1.1rem;
    bottom: 1.1rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.72rem 0.95rem;
    border-radius: 999px;
    color: #fff;
    background: rgba(10, 14, 22, 0.72);
    backdrop-filter: blur(12px);
    font-size: 0.92rem;
    font-weight: 750;
  }

  .show-summary {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border: 1px solid var(--show-line);
    border-radius: 1.5rem;
    background: linear-gradient(145deg, #fff 0%, #f9fbfc 100%);
    box-shadow: 0 20px 55px rgba(23, 32, 51, 0.08);
  }

  .show-kicker,
  .map-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--show-accent);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  .show-title {
    margin: 0.45rem 0 0.8rem;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .show-owner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--show-muted);
    margin: 0;
  }

  .owner-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(135deg, #172033, #fe424d);
    font-weight: 850;
  }

  .show-price-card {
    padding: 1.1rem;
    border: 1px solid rgba(23, 32, 51, 0.08);
    border-radius: 1.1rem;
    background: #fff;
  }

  .show-price-label {
    color: var(--show-muted);
    font-size: 0.78rem;
    font-weight: 750;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .show-price {
    margin: 0;
    font-size: 2rem;
    font-weight: 850;
  }

  .show-price span {
    color: var(--show-muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .show-meta-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  .show-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--show-line);
    border-radius: 1rem;
    background: var(--show-soft);
    color: #344054;
    font-weight: 700;
  }

  .show-meta i {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.8rem;
    color: var(--show-accent);
    background: #fff;
  }

  .show-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .show-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    padding: 0.72rem 1.05rem;
    border-radius: 999px;
    border: 0;
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
  }

  .show-action--primary {
    color: #fff;
    background: var(--show-ink);
  }

  .show-action--danger {
    color: #bb1d2a;
    background: #fff0f1;
  }

  .show-action:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(23, 32, 51, 0.13);
  }

  .show-content {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr);
    margin-top: 1.5rem;
  }

  .show-section {
    border: 1px solid var(--show-line);
    border-radius: 1.35rem;
    background: #fff;
    box-shadow: 0 16px 45px rgba(23, 32, 51, 0.06);
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .show-section-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 850;
  }

  .description-text {
    color: #4d5968;
    font-size: 1.02rem;
    line-height: 1.8;
    margin: 0;
  }

  .map-panel {
    overflow: hidden;
    padding: 0;
    background: linear-gradient(135deg, #f7f9fb 0%, #ffffff 48%, #fff5f5 100%);
  }

  .map-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem;
    padding: clamp(1.2rem, 3vw, 1.6rem);
  }

  .map-heading h4 {
    margin: 0.35rem 0 0;
    color: var(--show-ink);
    font-size: 1.5rem;
    font-weight: 850;
  }

  .map-address {
    color: var(--show-muted);
    margin: 0.4rem 0 0;
  }

  .map-frame-wrap {
    margin: 0 1.1rem 1.1rem;
    min-height: 380px;
    overflow: hidden;
    position: relative;
    border-radius: 1rem;
    border: 1px solid rgba(20, 30, 45, 0.12);
    background: #e9eef5;
  }

  .map-frame {
    width: 100%;
    height: 380px;
    border: 0;
    display: block;
  }

  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.7rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    color: #fff;
    background: var(--show-ink);
    font-size: 0.92rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 24px rgba(23, 32, 51, 0.18);
    transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
  }

  .map-link:hover {
    background: var(--show-accent);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(254, 66, 77, 0.24);
  }

  @media (max-width: 991px) {
    .show-hero {
      grid-template-columns: 1fr;
    }

    .show-media,
    .show-media img {
      min-height: 420px;
    }
  }

  @media (max-width: 767px) {
    .listing-show {
      padding-top: 0.5rem;
    }

    .show-media,
    .show-media img {
      min-height: 320px;
      border-radius: 1.1rem;
    }

    .show-summary,
    .show-section {
      border-radius: 1.1rem;
    }

    .show-actions,
    .show-action {
      width: 100%;
    }

    .map-heading {
      flex-direction: column;
    }

    .map-frame-wrap {
      margin: 0 0.8rem 0.8rem;
      min-height: 310px;
    }

    .map-frame {
      height: 310px;
    }
  }
</style>

<main class="listing-show">
  <div class="show-shell">
    <section class="show-hero">
      <div class="show-media">
        <img
          src="<%= listing.image.url %>"
          alt="<%= listing.title %>"
        />
        <span class="show-media-badge">
          <i class="fa-solid fa-location-dot"></i>
          <%= destination || "Destination" %>
        </span>
      </div>

      <aside class="show-summary">
        <div>
          <span class="show-kicker"><i class="fa-solid fa-route"></i> Curated tour</span>
          <h1 class="show-title"><%= listing.title %></h1>
          <p class="show-owner">
            <span class="owner-avatar"><%= listing.owner ? listing.owner.username.charAt(0).toUpperCase() : "U" %></span>
            Hosted by <strong><%= listing.owner ? listing.owner.username : "Unknown" %></strong>
          </p>
        </div>

        <div class="show-price-card">
          <p class="show-price-label">Starting from</p>
          <p class="show-price">
            &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Not Available" %>
            <span>/ day</span>
          </p>
        </div>

        <div class="show-meta-grid">
          <div class="show-meta">
            <i class="fa-solid fa-map-pin"></i>
            <span><%= listing.location || "Location not available" %></span>
          </div>
          <div class="show-meta">
            <i class="fa-solid fa-earth-asia"></i>
            <span><%= listing.country || "Country not available" %></span>
          </div>
          <div class="show-meta">
            <i class="fa-solid fa-star"></i>
            <span>
              <%= averageRating ? `${averageRating.toFixed(1)} rating` : "New listing" %>
              <%= reviewCount ? `(${reviewCount} review${reviewCount === 1 ? "" : "s"})` : "" %>
            </span>
          </div>
        </div>

        <% if(canManageListing) { %>
          <div class="show-actions">
            <a href="/listings/<%= listing._id %>/edit" class="show-action show-action--primary">
              <i class="fa-regular fa-pen-to-square"></i> Edit listing
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
              <button class="show-action show-action--danger" type="submit">
                <i class="fa-regular fa-trash-can"></i> Delete
              </button>
            </form>
          </div>
        <% } %>
      </aside>
    </section>

    <div class="show-content">
      <section class="show-section">
        <span class="show-kicker"><i class="fa-regular fa-compass"></i> Overview</span>
        <h2 class="show-section-title">About this experience</h2>
        <p class="description-text">
          <%= listing.description || "No description is available for this tour yet." %>
        </p>
      </section>

      <section class="show-section map-panel">
        <div class="map-heading">
          <div>
            <span class="map-kicker"><i class="fa-solid fa-map-location-dot"></i> Tour location</span>
            <h4>Explore the neighborhood</h4>
            <p class="map-address">
              <i class="fa-solid fa-location-dot me-2"></i><%= destination || "Location not available" %>
            </p>
          </div>
          <a
            class="map-link"
            href="https://www.google.com/maps/search/?api=1&query=<%= mapQuery %>"
            target="_blank"
            rel="noopener"
          >
            Open map <i class="fa-solid fa-up-right-from-square"></i>
          </a>
        </div>
        <div class="map-frame-wrap">
          <iframe
            class="map-frame"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps?q=<%= mapQuery %>&output=embed"
            title="Map showing <%= destination || listing.title %>"
          ></iframe>
        </div>
      </section>

      <section class="reviews-section">
        <div class="reviews-heading">
          <div>
            <span class="section-kicker">Guest feedback</span>
            <h4>Ratings &amp; reviews</h4>
          </div>
          <% if(reviewCount > 0) { %>
            <div class="rating-summary">
              <span class="rating-summary__score"><%= averageRating.toFixed(1) %></span>
              <span class="rating-summary__star"><i class="fa-solid fa-star"></i></span>
              <span class="rating-summary__count"><%= reviewCount %> review<%= reviewCount === 1 ? "" : "s" %></span>
            </div>
          <% } %>
        </div>

        <% if(currUser) { %>
          <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="review-composer needs-validation">
            <div class="review-composer__top">
              <div>
                <span class="review-composer__eyebrow">Share your experience</span>
                <h5>How was your tour?</h5>
              </div>
              <div class="star-rating" aria-label="Choose a rating from 1 to 5 stars">
                <% for(let ratingValue = 5; ratingValue >= 1; ratingValue--) { %>
                  <input
                    type="radio"
                    id="new-rating-<%= ratingValue %>"
                    name="review[rating]"
                    value="<%= ratingValue %>"
                    <%= ratingValue === 5 ? "required" : "" %>
                  />
                  <label for="new-rating-<%= ratingValue %>" title="<%= ratingValue %> star<%= ratingValue === 1 ? "" : "s" %>">
                    <i class="fa-solid fa-star"></i>
                  </label>
                <% } %>
              </div>
            </div>
            <div class="review-field">
              <label for="comment">Your review</label>
              <textarea name="review[comment]" id="comment" rows="4" placeholder="What stood out? Share a detail that could help future travellers." required></textarea>
              <div class="invalid-feedback">Please add a comment.</div>
            </div>
            <button class="review-submit" type="submit">
              Post review <i class="fa-solid fa-arrow-right"></i>
            </button>
          </form>
        <% } else { %>
          <div class="review-login">
            <i class="fa-regular fa-comment-dots"></i>
            <div>
              <strong>Been on this tour?</strong>
              <p><a href="/login">Log in</a> to share your experience.</p>
            </div>
          </div>
        <% } %>

        <% if(reviewCount > 0) { %>
          <div class="reviews-grid">
            <% for(review of listing.reviews) { %>
              <article class="review-card">
                <div class="review-card__header">
                  <div class="review-author">
                    <span class="review-avatar"><%= review.author ? review.author.username.charAt(0).toUpperCase() : "G" %></span>
                    <div>
                      <h6><%= review.author ? review.author.username : "Guest traveller" %></h6>
                      <span>Verified traveller</span>
                    </div>
                  </div>
                  <div class="review-score"><%= review.rating %>.0 <i class="fa-solid fa-star"></i></div>
                </div>
                <div class="review-stars" aria-label="<%= review.rating %> out of 5 stars">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <i class="<%= i <= review.rating ? "fa-solid" : "fa-regular" %> fa-star"></i>
                  <% } %>
                </div>
                <p class="review-card__comment"><%= review.comment %></p>
                <% if(review.createdAt) { %>
                  <time class="review-date"><%= new Date(review.createdAt).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %></time>
                <% } %>
                <div class="review-card__actions">
                  <% if(currUser && (isAdmin || (review.author && currUser._id.equals(review.author._id)))) { %>
                    <a class="review-action" href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit">
                      <i class="fa-regular fa-pen-to-square"></i> Edit
                    </a>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="review-action review-action--danger" type="submit">
                        <i class="fa-regular fa-trash-can"></i> Delete
                      </button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% } %>
          </div>
        <% } else { %>
          <div class="reviews-empty">
            <i class="fa-regular fa-star"></i>
            <h5>No reviews yet</h5>
            <p>Be the first traveller to share an experience.</p>
          </div>
        <% } %>
      </section>
    </div>
  </div>
</main>

<script>
  (() => {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.from(forms).forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
