<% layout('layouts/boilerplate') %>
<%
  const destination = [listing.location, listing.country].filter(Boolean).join(", ");
  const mapQuery = encodeURIComponent(destination || listing.title);
  const reviewCount = listing.reviews ? listing.reviews.length : 0;
  const averageRating = reviewCount
    ? listing.reviews.reduce((total, item) => total + item.rating, 0) / reviewCount
    : null;
  const canManageListing = currUser && (isAdmin || (listing.owner && currUser._id.equals(listing.owner._id)));
%>

<main class="show-page">
    <div class="show-shell">
        <section class="show-hero">
            <div class="show-media">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                <span class="show-media__badge">
                    <i class="fa-solid fa-location-dot"></i>
                    <%= destination || "Destination" %>
                </span>
                <button class="show-media__wish" type="button" aria-label="Save listing">
                    <i class="fa-regular fa-heart"></i>
                </button>
            </div>

            <aside class="show-summary">
                <div class="show-summary__head">
                    <span class="show-kicker"><i class="fa-solid fa-route"></i> Curated stay</span>
                    <h1><%= listing.title %></h1>
                    <p class="show-summary__owner">
                        <span class="show-avatar"><%= listing.owner ? listing.owner.username.charAt(0).toUpperCase() : "U" %></span>
                        Hosted by <strong><%= listing.owner ? listing.owner.username : "Unknown" %></strong>
                    </p>
                </div>

                <div class="show-price">
                    <span class="show-price__label">Price per night</span>
                    <div class="show-price__value">
                        &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Not Available" %>
                        <small>/ night</small>
                    </div>
                </div>

                <div class="show-facts">
                    <div class="show-fact">
                        <i class="fa-solid fa-map-pin"></i>
                        <span><%= listing.location || "Location not available" %></span>
                    </div>
                    <div class="show-fact">
                        <i class="fa-solid fa-earth-asia"></i>
                        <span><%= listing.country || "Country not available" %></span>
                    </div>
                    <div class="show-fact">
                        <i class="fa-solid fa-star"></i>
                        <span>
                            <%= averageRating ? `${averageRating.toFixed(1)} rating` : "New listing" %>
                            <%= reviewCount ? `(${reviewCount} review${reviewCount === 1 ? "" : "s"})` : "" %>
                        </span>
                    </div>
                </div>

                <div class="show-cart">
                    <div>
                        <span class="section-kicker">Cart</span>
                        <h2>Add to cart</h2>
                        <p>Save this stay to your trip cart and review it later in one place.</p>
                    </div>
                    <div class="show-cart__actions">
                        <form method="POST" action="/cart/<%= listing._id %>" class="m-0">
                            <button class="show-btn show-btn--primary show-cart__btn" type="submit" <%= inCart ? "disabled" : "" %>>
                                <i class="fa-solid fa-cart-shopping"></i>
                                <%= inCart ? "Already in cart" : "Add to cart" %>
                            </button>
                        </form>
                        <a href="/cart" class="show-cart__link">
                            View cart
                            <span>(<%= cartCount || 0 %>)</span>
                        </a>
                    </div>
                </div>

                <% if(canManageListing) { %>
                    <div class="show-actions">
                        <a href="/listings/<%= listing._id %>/edit" class="show-btn show-btn--primary">
                            <i class="fa-regular fa-pen-to-square"></i>
                            Edit listing
                        </a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                            <button class="show-btn show-btn--danger" type="submit">
                                <i class="fa-regular fa-trash-can"></i>
                                Delete
                            </button>
                        </form>
                    </div>
                <% } %>
            </aside>
        </section>

        <section class="show-grid">
            <article class="show-panel">
                <span class="section-kicker">About</span>
                <h2>About this experience</h2>
                <p><%= listing.description || "No description is available for this tour yet." %></p>
            </article>

            <article class="show-panel show-panel--map">
                <div class="show-panel__head">
                    <div>
                        <span class="section-kicker">Location</span>
                        <h2>Explore the neighborhood</h2>
                        <p><%= destination || "Location not available" %></p>
                    </div>
                    <a
                        class="show-map-link"
                        href="https://www.google.com/maps/search/?api=1&query=<%= mapQuery %>"
                        target="_blank"
                        rel="noopener"
                    >
                        Open map
                        <i class="fa-solid fa-up-right-from-square"></i>
                    </a>
                </div>
                <div class="show-map">
                    <iframe
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://www.google.com/maps?q=<%= mapQuery %>&output=embed"
                        title="Map showing <%= destination || listing.title %>"
                    ></iframe>
                </div>
            </article>
        </section>

        <section class="reviews-section">
            <div class="reviews-heading">
                <div>
                    <span class="section-kicker">Guest feedback</span>
                    <h4>Ratings &amp; reviews</h4>
                </div>
                <% if(reviewCount > 0) { %>
                    <div class="rating-summary">
                        <span class="rating-summary__score"><%= averageRating.toFixed(1) %></span>
                        <span class="rating-summary__star"><i class="fa-solid fa-star"></i></span>
                        <span class="rating-summary__count"><%= reviewCount %> review<%= reviewCount === 1 ? "" : "s" %></span>
                    </div>
                <% } %>
            </div>

            <% if(currUser) { %>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="review-composer needs-validation">
                    <div class="review-composer__top">
                        <div>
                            <span class="review-composer__eyebrow">Share your experience</span>
                            <h5>How was your tour?</h5>
                        </div>
                        <div class="star-rating" aria-label="Choose a rating from 1 to 5 stars">
                            <% for(let ratingValue = 5; ratingValue >= 1; ratingValue--) { %>
                                <input
                                    type="radio"
                                    id="new-rating-<%= ratingValue %>"
                                    name="review[rating]"
                                    value="<%= ratingValue %>"
                                    <%= ratingValue === 5 ? "required" : "" %>
                                />
                                <label for="new-rating-<%= ratingValue %>" title="<%= ratingValue %> star<%= ratingValue === 1 ? "" : "s" %>">
                                    <i class="fa-solid fa-star"></i>
                                </label>
                            <% } %>
                        </div>
                    </div>
                    <div class="review-field">
                        <label for="comment">Your review</label>
                        <textarea name="review[comment]" id="comment" rows="4" placeholder="What stood out? Share a detail that could help future travellers." required></textarea>
                        <div class="invalid-feedback">Please add a comment.</div>
                    </div>
                    <button class="review-submit" type="submit">
                        Post review
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </form>
            <% } else { %>
                <div class="review-login">
                    <i class="fa-regular fa-comment-dots"></i>
                    <div>
                        <strong>Been on this tour?</strong>
                        <p><a href="/login">Log in</a> to share your experience.</p>
                    </div>
                </div>
            <% } %>

            <% if(reviewCount > 0) { %>
                <div class="reviews-grid">
                    <% for(review of listing.reviews) { %>
                        <article class="review-card">
                            <div class="review-card__header">
                                <div class="review-author">
                                    <span class="review-avatar"><%= review.author ? review.author.username.charAt(0).toUpperCase() : "G" %></span>
                                    <div>
                                        <h6><%= review.author ? review.author.username : "Guest traveller" %></h6>
                                        <span>Verified traveller</span>
                                    </div>
                                </div>
                                <div class="review-score"><%= review.rating %>.0 <i class="fa-solid fa-star"></i></div>
                            </div>
                            <div class="review-stars" aria-label="<%= review.rating %> out of 5 stars">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="<%= i <= review.rating ? "fa-solid" : "fa-regular" %> fa-star"></i>
                                <% } %>
                            </div>
                            <p class="review-card__comment"><%= review.comment %></p>
                            <% if(review.createdAt) { %>
                                <time class="review-date"><%= new Date(review.createdAt).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) %></time>
                            <% } %>
                            <div class="review-card__actions">
                                <% if(currUser && (isAdmin || (review.author && currUser._id.equals(review.author._id)))) { %>
                                    <a class="review-action" href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit">
                                        <i class="fa-regular fa-pen-to-square"></i> Edit
                                    </a>
                                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                        <button class="review-action review-action--danger" type="submit">
                                            <i class="fa-regular fa-trash-can"></i> Delete
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </article>
                    <% } %>
                </div>
            <% } else { %>
                <div class="reviews-empty">
                    <i class="fa-regular fa-star"></i>
                    <h5>No reviews yet</h5>
                    <p>Be the first traveller to share an experience.</p>
                </div>
            <% } %>
        </section>
    </div>
</main>

<script>
  (() => {
    'use strict'
    const forms = document.querySelectorAll('.needs-validation')
    Array.from(forms).forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
  })()
</script>
