<% layout("layouts/boilerplate") %>

<div class="auth-page auth-page--login">
    <section class="auth-card">
        <aside class="auth-visual auth-visual--login">
            <span class="auth-kicker"><i class="fa-solid fa-sparkles"></i> Welcome back</span>
            <h1 class="auth-visual__title">Sign in and pick up right where you left off.</h1>
            <p>
                Manage your listings, keep browsing your saved destinations, and return to your travel flow in one tap.
            </p>

            <div class="auth-badges">
                <span><i class="fa-solid fa-bolt"></i> Fast access</span>
                <span><i class="fa-solid fa-shield-heart"></i> Secure session</span>
                <span><i class="fa-solid fa-mobile-screen-button"></i> Mobile ready</span>
            </div>
        </aside>

        <div class="auth-panel">
            <div class="auth-panel__header">
                <span class="auth-kicker auth-kicker--soft">Sign in</span>
                <h2>Log in to Wanderlust</h2>
                <p>Use your account email and password to continue.</p>
            </div>

            <form action="/login" method="POST" class="needs-validation auth-form" novalidate>
                <div class="auth-field">
                    <label for="email" class="form-label">Email</label>
                    <div class="auth-input-wrap">
                        <i class="fa-regular fa-envelope"></i>
                        <input
                            name="email"
                            id="email"
                            type="email"
                            class="form-control"
                            placeholder="you@example.com"
                            required
                        />
                    </div>
                </div>

                <div class="auth-field">
                    <label for="password" class="form-label">Password</label>
                    <div class="auth-input-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input
                            name="password"
                            id="password"
                            type="password"
                            class="form-control"
                            placeholder="Enter your password"
                            required
                        />
                    </div>
                </div>

                <button class="btn auth-submit auth-submit--login" type="submit">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    Login
                </button>
            </form>
        </div>
    </section>
</div>
