<header class="topbar">
    <div class="topbar__inner">
        <a class="topbar__brand" href="/listings" aria-label="Wander home">
            <span class="topbar__brand-mark"><i class="fa-solid fa-plane-departure"></i></span>
            <span class="topbar__brand-text">
                <strong>Wander</strong>
                <small>Travel booking</small>
            </span>
        </a>

        <form class="topbar__search" action="/listings" method="GET" role="search">
            <% if(activeCategory) { %>
                <input type="hidden" name="category" value="<%= activeCategory %>">
            <% } %>
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <input
                type="search"
                name="search"
                value="<%= searchTerm || '' %>"
                placeholder="Start your search"
                aria-label="Search destinations"
            >
            <button type="submit">Search</button>
        </form>

        <button
            class="topbar__menu-btn"
            type="button"
            aria-expanded="false"
            aria-controls="topbarMenu"
            data-mobile-menu-toggle
        >
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>

    <div class="topbar__menu" id="topbarMenu" data-mobile-menu hidden>
        <div class="topbar__menu-grid">
            <a href="/listings" class="topbar__menu-link">
                <i class="fa-solid fa-compass"></i>
                <span>Explore</span>
            </a>
            <a href="/cart" class="topbar__menu-link topbar__cart">
                <i class="fa-solid fa-cart-shopping"></i>
                <span>Cart<% if(cartCount && cartCount > 0) { %> (<%= cartCount %>)<% } %></span>
            </a>
            <% if(currUser) { %>
                <a href="/listings/new" class="topbar__menu-link">
                    <i class="fa-solid fa-circle-plus"></i>
                    <span>Add Tour</span>
                </a>
                <a href="/logout" class="topbar__menu-link">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Log out</span>
                </a>
            <% } else { %>
                <a href="/login" class="topbar__menu-link">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Sign in</span>
                </a>
                <a href="/signup" class="topbar__menu-link">
                    <i class="fa-solid fa-user-plus"></i>
                    <span>Create account</span>
                </a>
            <% } %>
            <button class="topbar__menu-link topbar__theme" type="button" id="themeToggle">
                <i class="fa-regular fa-moon"></i>
                <span>Theme</span>
            </button>
        </div>
    </div>
</header>
